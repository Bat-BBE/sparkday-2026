// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  CASH
  BANK
  CARD
  SAVINGS
}

enum TxnType {
  INCOME
  EXPENSE
  TRANSFER
}

enum DebtKind {
  LOAN
  RECEIVABLE
}

enum DebtStatus {
  OPEN
  CLOSED
}

model User {
  id                   String   @id @default(cuid())
  fullName             String
  email                String   @unique
  passwordHash         String
  ageRange             String?
  gender               String?
  hasLoan              Boolean  @default(false)
  hasSavings           Boolean  @default(false)
  profileImageBase64   String?
  incomeSources        String[]
  expenseSources       String[]
  customIncomeSources  String[]
  customExpenseSources String[]
  theme                String   @default("violet")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  accounts             Account[]
  transactions         Transaction[]
  debts                Debt[]
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AccountType @default(BANK)
  currency  String      @default("MNT")
  // Store a snapshot; balance can be derived later.
  balance   Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String
  accountId  String
  type       TxnType
  // Amount in MNT (integer), income positive, expense positive (use type for sign).
  amount     Int
  category   String?
  note       String?
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
  @@index([accountId, occurredAt])
}

model Debt {
  id           String     @id @default(cuid())
  userId       String
  kind         DebtKind
  status       DebtStatus @default(OPEN)
  counterparty String
  amount       Int
  dueDate      DateTime?
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}
